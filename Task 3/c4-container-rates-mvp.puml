@startuml
!include <C4/C4_Container>

' c4plantuml-state: target MVP
' c4plantuml-scope: система управления ставками MVP открытия депозитов и накопительных счетов онлайн
' c4plantuml-evidence: F1,F5-F6,F9,F11,F29-F30,R1,R4-R5,P2-P3,S1-S4,+5-+7,+10

LAYOUT_LEFT_RIGHT()
AddRelTag("async", $legendText="Асинхронное событие", $lineStyle=DashedLine())

title Банк "Стандарт" - C4 Container: система управления ставками

Person(backoffice_deposit_manager, "Менеджер бэк-офиса депозитов", "Ведет и проверяет депозитные ставки")

System_Ext(digital_channels, "Цифровые каналы банка", "Показывают опубликованные общие ставки")
System_Ext(applications, "Система работы с заявками", "Запрашивает ставку по заявке")
System_Ext(accounts, "Система счетов", "Предоставляет признаки клиента и крупных остатков")
System_Ext(kafka, "Kafka", "Публикация обновлений ставок")

System_Boundary(rates_system, "Система управления ставками") {
  Container(rates_service, "Сервис ставок", "ASP.NET Core/.NET", "Управляет общими, персональными и специальными ставками")
  ContainerDb(rates_db, "БД сервиса ставок", "MS SQL", "Версии ставок, история изменений и параметры правил")
}

Rel(backoffice_deposit_manager, rates_service, "Загружает, проверяет и публикует ставки")
Rel_D(rates_service, rates_db, "Ставки, версии и история")
Rel_R(digital_channels, rates_service, "Получение опубликованных общих ставок", "HTTPS / cache integration")
Rel_R(applications, rates_service, "Ставка по конкретной заявке", "HTTPS")
Rel_R(rates_service, accounts, "Признаки для специальных ставок", "HTTPS")
Rel_R(rates_service, kafka, "События обновления общих ставок", "Kafka", $tags="async")

SHOW_LEGEND()

@enduml
